# modern_quickstart.mellow — recommended modern syntax (Python-like)
let name = "Mellow"
print("Hello", name)

def add(a, b):
    return a + b

print("2+3 =", add(2, 3))

# for-range style (recommended)
for i in 0..3:
    print("i =", i)

# while style
let n = 3
while n > 0:
    print("count", n)
    n = n - 1
