radius = 10
y = 0 - radius

while y <= radius:
    line = ""
    x = 0 - radius

    while x <= radius:
        distance = x * x + y * y

        if distance <= radius * radius:
            line = line + "●"
        else:
            line = line + " "

        x = x + 1

    print(line)
    y = y + 1