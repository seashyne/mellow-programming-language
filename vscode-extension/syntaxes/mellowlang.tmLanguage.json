{
  "scopeName": "source.mellow",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#modules"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.frinds",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.mellow",
          "match": "#.*$"
        },
        {
          "name": "comment.line.semicolon.frinds",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.frinds",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.frinds",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.frinds",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.frinds",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.frinds",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.frinds",
          "match": "\\b(if|else|elif|check|also|end|then|do|while|for|in|loop|range|repeat|until|break|continue|return|stop|wait|def|fn|func|function|skill|let|var|keep|const|true|false|none|null|nil|and|or|not|import|use|need|as|get|call|emit|on|try|catch|finally|save|load|into|put|show|precision)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.mellow",
          "match": "\\b(print|println|write|input|readline|read_line|ask|args|argv|cwd|sleep_ms|exit|len|str|type|abs|floor|ceil|sqrt|min|max|range|clock_ms|getenv|gc_collect|gc_stats|spawn|yield|channel|send|recv)\\b(?=\\s*\\()"
        }
      ]
    },
    "modules": {
      "patterns": [
        {
          "name": "support.module.mellow",
          "match": "\\b(io|sys|math|time|gc|thread|chan)\\b(?=\\.)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.frinds",
          "match": "\\b(vec|vector|vec2|vec3|vec4|list|map|string|number|bool)\\b"
        }
      ]
    }
  }
}
