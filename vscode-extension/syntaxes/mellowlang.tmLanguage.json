{
  "scopeName": "source.mellow",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.frinds",
          "match": "//.*$"
        },
        {
          "name": "comment.line.semicolon.frinds",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.frinds",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.frinds",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.frinds",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.frinds",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.frinds",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.frinds",
          "match": "\\b(if|else|elif|end|then|do|while|for|in|range|repeat|until|break|continue|return|fn|func|let|var|const|true|false|nil|null|and|or|not|import|emit)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.frinds",
          "match": "\\b(vec|vector|vec2|vec3|vec4|list|map|string|number|bool)\\b"
        }
      ]
    }
  }
}