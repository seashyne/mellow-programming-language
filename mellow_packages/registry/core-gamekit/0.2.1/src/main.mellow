def scene(name):
    return game.scene_create(name)

def entity(name, state):
    return {"name": name, "state": state}

def spawn(name, x, y):
    return game.entity_create(name, x, y, 1, 1)

def move(entity, dx, dy):
    return game.entity_move(entity, dx, dy)

def tween(a, b, t):
    return game.tween(a, b, t, "out_quad")

def collide(a, b):
    return game.collide_aabb(a, b)

def to_json(value):
    return json.encode(value)
